# Base URL of the Flora CMS API (server-only — do NOT prefix with NEXT_PUBLIC_).
FLORA_API_URL=http://localhost:5253

# Seconds Next.js caches the UI config before revalidating (admin changes go live
# within this window, with no rebuild). Defaults to 60.
FLORA_CONFIG_REVALIDATE=60

# Shared secret for the POST /api/revalidate webhook. The CMS calls this after a
# theme save to invalidate the cache instantly. Leave unset to disable the route.
FLORA_REVALIDATE_SECRET=change-me-to-a-random-secret

# Contact form posts to FLORA_API_URL/api/contact via app/api/contact (no extra vars needed).
